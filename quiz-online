#!/usr/bin/env bash
# Bring the quiz back ONLINE before a game night. Redeploys the latest code and
# the link is live again in about a minute. Run from the project folder.
set -e
REPO="JJ-WCW/music-quiz"
URL="https://jj-wcw.github.io/music-quiz/"

echo "Bringing the quiz online…"
# (re)create the Pages site from main/root; harmless if it already exists
gh api -X POST "repos/$REPO/pages" -f "source[branch]=main" -f "source[path]=/" >/dev/null 2>&1 || true
# make sure it's building the latest commit
gh api -X POST "repos/$REPO/pages/builds" >/dev/null 2>&1 || true

echo "⏳ Redeploying… waiting for the link to come alive:"
for i in $(seq 1 24); do
  code=$(curl -s -o /dev/null -w "%{http_code}" "$URL?ping=$(date +%s)")
  if [ "$code" = "200" ]; then
    echo "✅ Online: $URL"
    exit 0
  fi
  sleep 10
done
echo "⚠️  Still not live after 4 minutes — check https://github.com/$REPO/settings/pages"
